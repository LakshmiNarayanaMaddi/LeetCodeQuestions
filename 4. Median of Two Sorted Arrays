Given two sorted arrays nums1 and nums2 of size m and n respectively, return the median of the two sorted arrays.
The overall run time complexity should be O(log (m+n)).
Example 1:
Input: nums1 = [1,3], nums2 = [2]
Output: 2.00000
Explanation: merged array = [1,2,3] and median is 2.
Example 2:
Input: nums1 = [1,2], nums2 = [3,4]
Output: 2.50000
Explanation: merged array = [1,2,3,4] and median is (2 + 3) / 2 = 2.5.
===========================================================================
class Solution {
    public double findMedianSortedArrays(int[] nums1, int[] nums2) {
        if (nums1.length == 0 || nums2.length == 0) {
            if (nums1.length == 0) {
                if (nums2.length == 1) {
                    return (double) nums2[0];
                }
                return median(nums2);
            } else {
                if (nums1.length == 1) {
                    return (double) nums1[0];
                }
                return median(nums1);
            }
        } else {
            int[] sortedArray = sortedArray(nums1, nums2);
            return median(sortedArray);
        }

    }

    private double median(int[] nums) {
        int output = nums.length / 2;
        if (nums.length % 2 != 0) {
            return (double) nums[output];
        } else {
            return (double) (nums[output] + nums[output - 1]) / 2;
        }
    }

    private int[] sortedArray(int[] nums1, int[] nums2) {
        int[] sortedArray = new int[nums1.length + nums2.length];
        int length = sortedArray.length;
        int j = 0, k = 0, i = 0;
        while (i < length && j < nums1.length && k < nums2.length) {
            if (nums1[j] < nums2[k]) {
                sortedArray[i] = nums1[j];
                j++;
                i++;
            } else if (nums1[j] == nums2[k]) {
                sortedArray[i] = nums1[j];
                i++;
                sortedArray[i] = nums1[j];
                j++;
                k++;
                i++;
            } else {
                sortedArray[i] = nums2[k];
                k++;
                i++;
            }
        }

        if (j == nums1.length) {
            for (int l = i; l < length; l++) {
                sortedArray[l] = nums2[k];
                k++;
            }
        } else if (k == nums2.length) {
            for (int l = i; l < length; l++) {
                sortedArray[l] = nums1[j];
                j++;
            }
        } else {

        }
        return (sortedArray);
    }

}
